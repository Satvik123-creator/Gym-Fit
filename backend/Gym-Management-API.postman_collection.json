{
  "info": {
    "name": "Gym Management API",
    "description": "Complete Postman collection for the Gym Management System API. Includes endpoints for authentication, trainers, membership plans, gallery, testimonials, transformations, enquiries, trial bookings, gym info, and health checks.\n\n## Authentication\n\nMost endpoints require authentication. After logging in via the **Login** endpoint, copy the returned `accessToken` and set it as the `accessToken` collection variable. Protected routes will automatically use this token via the collection-level Bearer auth.\n\n## Variables\n\n| Variable | Initial Value | Description |\n|----------|--------------|-------------|\n| baseUrl | http://localhost:5000/api | API base URL |\n| accessToken | (empty) | JWT access token for authenticated requests |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "gym-fit"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints - login and token refresh. These endpoints do not require authentication.",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gym.com\",\n  \"password\": \"Admin@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate with admin credentials. On success, returns an access token and a refresh token. Set the access token as the `accessToken` collection variable for subsequent authenticated requests."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token-here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Obtain a new access token by providing a valid refresh token."
          },
          "response": []
        }
      ]
    },
